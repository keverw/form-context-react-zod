{
  "name": "form-context-react-zod",
  "private": true,
  "version": "2.0.0",
  "description": "React form context with Zod validation helpers",
  "type": "module",
  "author": "Kevin Whitman (https://github.com/keverw)",
  "license": "MIT",
  "homepage": "https://github.com/keverw/form-context-react-zod#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/keverw/form-context-react-zod"
  },
  "bugs": {
    "url": "https://github.com/keverw/form-context-react-zod/issues"
  },
  "keywords": [
    "react",
    "form",
    "zod",
    "validation",
    "context"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check-deps": "bun run scripts/check-deps.ts",
    "update-docs": "bun run scripts/update-docs.ts",
    "build:lib": "bun run check-deps && bun run update-docs && bun run scripts/build-lib.ts",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,html}\"",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepublishOnly": "bun audit --prod && bun run type-check && bun run lint && bun test && bun run build:lib",
    "publish:lib": "bun run prepublishOnly && cd dist_module && bun publish",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@happy-dom/global-registrator": "^20.10.3",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "prettier": "3.8.4",
    "semver": "^7.8.4",
    "tailwindcss": "^4",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16"
  }
}
