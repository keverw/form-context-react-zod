{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://github.com/keverw/form-context-react-zod",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "node build-lib.js",
    "publish:lib": "npm run build:lib && cd dist_module && npm publish",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,html}\"",
    "test": "vitest run --bail=1 --coverage",
    "test:watch": "vitest watch",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsup": "8.5.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "^3.1.3",
    "autoprefixer": "^10.5.0",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "^3.4.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vitest": "^3.1.3"
  }
}
