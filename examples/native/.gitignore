# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Lockfiles: this example installs with npm (file: dep) and its lockfile is not
# committed — only the repo root's bun.lock is tracked. Ignore any lockfile
# generated here (incl. bun.lock, in case someone runs `bun install` here).
package-lock.json
bun.lock
bun.lockb
yarn.lock
pnpm-lock.yaml

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
